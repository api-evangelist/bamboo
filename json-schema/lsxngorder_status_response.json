{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.investbamboo.com/schemas/lsxngorder_status_response",
  "title": "NGX Order status response",
  "type": "object",
  "properties": {
    "dollar_fee": {
      "type": "number",
      "description": "Dollar Fee",
      "example": 0.42
    },
    "dollar_price": {
      "type": "number",
      "description": "Dollar equivalent of price for order",
      "example": 0.42
    },
    "id": {
      "type": "string",
      "description": "Order ID",
      "example": "BB.LAMB_21046bcd-0400-4ac1-a6a1-91c439455ef2"
    },
    "naira_fee": {
      "type": "float",
      "description": "Naira fee",
      "example": 33.15
    },
    "naira_price": {
      "type": "number",
      "description": "Naira price for order",
      "example": 364.65
    },
    "price": {
      "type": "number",
      "description": "Price",
      "example": 33.15
    },
    "quantity": {
      "type": "number",
      "description": "Quantity requested",
      "example": 10
    },
    "side": {
      "type": "string",
      "description": "Side; BUY or SELL",
      "example": "BUY"
    },
    "status": {
      "type": "string",
      "description": "Status",
      "example": "Successful"
    },
    "symbol": {
      "type": "string",
      "description": "Stock symbol to `BUY` or `SELL`",
      "default": "DDD"
    },
    "type": {
      "type": "string",
      "description": "Type: MARKET, STOP, LIMIT",
      "example": "MARKET"
    }
  }
}