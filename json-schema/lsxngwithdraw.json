{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.investbamboo.com/schemas/lsxngwithdraw",
  "title": "NGX Withdrawal Request body",
  "required": [
    "amount",
    "currency",
    "txref"
  ],
  "type": "object",
  "properties": {
    "amount": {
      "type": "integer",
      "description": "amount",
      "example": 1000
    },
    "currency": {
      "type": "string",
      "description": "currency",
      "example": "NGN"
    },
    "txref": {
      "type": "string",
      "description": "reference",
      "example": "INVKPxiJVc40BNaQBH"
    }
  }
}