{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.investbamboo.com/schemas/lsxngwithdraw_by_reference_response",
  "title": "Withdraw status",
  "required": [
    "withdraw_type",
    "title"
  ],
  "type": "object",
  "properties": {
    "withdraw_type": {
      "type": "number",
      "description": "Amount to be deposited",
      "example": 1000
    },
    "title": {
      "type": "string",
      "description": "Currency",
      "example": "NGN"
    }
  }
}