{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.investbamboo.com/schemas/MarketOrderRequest",
  "title": "MarketOrderRequest",
  "type": "object",
  "properties": {
    "order_type": {
      "type": "string",
      "description": "Order type options: `MARKET`, `LIMIT`, `STOP`",
      "enum": [
        "MARKET"
      ]
    },
    "symbol": {
      "type": "string",
      "description": "Stock ticker symbol",
      "example": "AAPL"
    },
    "side": {
      "type": "string",
      "description": "BUY or SELL",
      "enum": [
        "buy",
        "sell"
      ]
    },
    "amount": {
      "type": "number",
      "description": "Investment amount",
      "default": 100000
    },
    "sell_all": {
      "type": "boolean",
      "description": "set to true if the user wants to sell_all the shares they have for the specified stock symbol.",
      "example": false
    }
  },
  "required": [
    "order_type",
    "symbol",
    "side",
    "amount"
  ]
}